              "expr": "format('$baseUrl = \"{0}\"\nif (\"{1}\" -ne \"\") {{ $baseUrl = \"{2}\" }}\nif (-not $baseUrl) {{ $baseUrl = \"http://192.168.150.162:8080\" }}\n\n$version = \"unknown\"\n$endpoints = @(\"/health\", \"/version\", \"/api/version\", \"/api/v1/version\", \"/api/v2/version\")\n\nforeach ($ep in $endpoints) {{\n  try {{\n    $resp = Invoke-RestMethod -Uri \"$baseUrl$ep\" -TimeoutSec 5 -ErrorAction Stop\n    # version / commit / build_hash 필드를 순서대로 탐색\n    $candidate = $null\n    if ($resp.version) {{ $candidate = $resp.version }}\n    elseif ($resp.commit) {{ $candidate = $resp.commit }}\n    elseif ($resp.build_hash) {{ $candidate = $resp.build_hash }}\n    elseif ($resp.hash) {{ $candidate = $resp.hash }}\n    if ($candidate) {{\n      $version = $candidate\n      Write-Host \"[Version] $ep → $version\"\n      break\n    }}\n    # 응답 자체가 문자열인 경우\n    if ($resp -is [string] -and $resp.Length -lt 100) {{\n      $version = $resp.Trim()\n      Write-Host \"[Version] $ep → $version\"\n      break\n    }}\n  }} catch {{\n    Write-Host \"[Version] $ep 접근 실패: $_\"\n  }}\n}}\n\nWrite-Host \"[Version] 최종 서버 버전: $version\"\n\"version=$version\" | Out-File $env:GITHUB_OUTPUT -Append\n', vars.SERVER_BASE_URL, inputs.base_url, inputs.base_url)"
