              "col": 14,
              "lit": "try {\n  $resp = Invoke-RestMethod -Uri \"$env:OLLAMA_BASE_URL/api/tags\" -Method Get -TimeoutSec 10\n  if (-not $resp.models) {\n    Write-Error \"Ollama is reachable but no models are installed.\"\n    exit 1\n  }\n  $models = @($resp.models | ForEach-Object { $_.name })\n  Write-Host \"[Ollama] Installed models: $($models -join ', ')\"\n\n  if ($models -notcontains $env:LLM_MODEL) {\n    Write-Error \"Required model '$env:LLM_MODEL' is not installed in Ollama.\"\n    exit 1\n  }\n} catch {\n  Write-Error \"Ollama health check failed: $_\"\n  exit 1\n}\n"
