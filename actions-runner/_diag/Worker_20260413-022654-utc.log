              "line": 375,
              "col": 14,
              "expr": "format('[Console]::OutputEncoding = [System.Text.Encoding]::UTF8\n\n# 이전 step 결과 읽기\n$serverUpRaw = \"{0}\"\n$exitCodeRaw = \"{1}\"\n\nWrite-Host \"[Result] server_up=''$serverUpRaw''  pytest_exit=''$exitCodeRaw''\"\n\n# 1. 서버 크래시 여부\nif ($serverUpRaw -eq \"false\") {{\n  Write-Host \"::error::Server crashed during test run. Check crash-log artifacts.\"\n  exit 2\n}}\n\n# 2. pytest 결과 — 빈 문자열(step skip) 은 통과로 처리\nif ($exitCodeRaw -ne \"\" -and $exitCodeRaw -ne \"0\") {{\n  $code = 0\n  if ([int]::TryParse($exitCodeRaw, [ref]$code)) {{\n    Write-Host \"::error::pytest failed (exit=$code). Check uploaded test reports.\"\n    exit $code\n  }} else {{\n    Write-Host \"::error::pytest exit code unreadable: ''$exitCodeRaw''\"\n    exit 1\n  }}\n}}\n\nWrite-Host \"[Result] Pipeline completed successfully.\"', steps.post_health.outputs.server_up, steps.pytest.outputs.exit_code)"
            }
          },
