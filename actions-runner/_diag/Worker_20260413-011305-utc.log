              "lit": "$healthUrl  = \"$env:BASE_URL/health\"\n$maxRetries = 6      # SCM 재기동 대기 최대 3분 (30초 × 6)\n$retryDelay = 30\n$serverUp   = $false\n\nfor ($i = 1; $i -le $maxRetries; $i++) {\n  try {\n    $resp = Invoke-WebRequest -Uri $healthUrl -TimeoutSec 5 -UseBasicParsing -ErrorAction Stop\n    if ($resp.StatusCode -lt 500) {\n      Write-Host \"[Health] OK (HTTP $($resp.StatusCode))\"\n      $serverUp = $true\n      break\n    }\n  } catch {\n    Write-Host \"[Health] 시도 $i/$maxRetries 실패: $_\"\n  }\n  if ($i -lt $maxRetries) {\n    Write-Host \"[Health] ${retryDelay}초 후 재시도... (SCM 재기동 대기)\"\n    Start-Sleep -Seconds $retryDelay\n  }\n}\n\n\"server_up=$($serverUp.ToString().ToLower())\" | Out-File $env:GITHUB_OUTPUT -Append\nif (-not $serverUp) {\n  Write-Host \"::warning::서버가 응답하지 않습니다. 로그를 수집합니다.\"\n}\n"
            }
