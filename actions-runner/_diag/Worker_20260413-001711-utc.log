              "line": 72,
              "col": 14,
              "lit": "$swaggerFiles = @()\nif (Test-Path \"input\") {\n  $swaggerFiles += Get-ChildItem -Path \"input\" -Include \"*.yaml\",\"*.yml\",\"*.json\" -Recurse\n}\nforeach ($extra in @(\"QFEapi.yaml\",\"QFEapi.json\")) {\n  if (Test-Path $extra) { $swaggerFiles += Get-Item $extra }\n}\n\nif ($swaggerFiles.Count -eq 0) {\n  Write-Error \"Swagger 파일을 찾을 수 없습니다.\"\n  exit 1\n}\n\n$hasher   = [System.Security.Cryptography.SHA256]::Create()\n$combined = \"\"\nforeach ($f in ($swaggerFiles | Sort-Object FullName)) {\n  $bytes = [System.IO.File]::ReadAllBytes($f.FullName)\n  $h     = [System.BitConverter]::ToString($hasher.ComputeHash($bytes)).Replace(\"-\",\"\").ToLower()\n  $combined += \"$($f.Name):$h;\"\n  Write-Host \"[Hash] $($f.Name) → $h\"\n}\n$finalHash = [System.BitConverter]::ToString(\n  $hasher.ComputeHash([System.Text.Encoding]::UTF8.GetBytes($combined))\n).Replace(\"-\",\"\").ToLower()\n\nWrite-Host \"[Hash] 최종 Swagger 해시: $finalHash\"\n\"swagger_hash=$finalHash\" | Out-File $env:GITHUB_OUTPUT -Append\n"
